{
  "name": "@chat4000/openclaw-plugin",
  "version": "2.0.0",
  "description": "OpenClaw channel plugin for chat4000 — routes agent messages over Matrix (Tuwunel) end-to-end encrypted rooms",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "files": [
    "README.md",
    "index.ts",
    "channel-plugin-api.ts",
    "openclaw.plugin.json",
    "src/**/*.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare-release": "python3.12 scripts/publish_npm.py --prepare-only --from-file",
    "publish:npm": "python3.12 scripts/publish_npm.py",
    "publish:npm:dry-run": "python3.12 scripts/publish_npm.py --dry-run",
    "build": "tsc",
    "test": "vitest run --project unit",
    "test:contract": "vitest run --project contract",
    "test:all": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.27"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "chat4000",
      "label": "chat4000",
      "selectionLabel": "chat4000 (iOS/macOS app)",
      "detailLabel": "chat4000",
      "docsPath": "/channels/chat4000",
      "docsLabel": "chat4000",
      "blurb": "Connect your chat4000 iOS/macOS app over a Matrix homeserver",
      "systemImage": "iphone",
      "order": 80
    },
    "install": {
      "minHostVersion": ">=2026.5.27"
    }
  },
  "dependencies": {
    "@matrix-org/matrix-sdk-crypto-wasm": "^18.3.0",
    "@sentry/node": "^8.55.1",
    "fake-indexeddb": "^6.0.0",
    "markdown-it": "^14.1.0",
    "matrix-encrypt-attachment": "^1.0.3",
    "matrix-js-sdk": "^41.6.0",
    "qrcode-terminal": "^0.12.0"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
